# Obsidian vault — caminho absoluto para a pasta do vault
# Windows nativo:   C:/Users/Hermes/Documents/MeuVault
# WSL2:             /mnt/c/Users/Hermes/Documents/MeuVault
# Use a pasta vault/ incluída no projeto para começar:
OBSIDIAN_VAULT_PATH=./vault

# Apenas em desenvolvimento local com proxy SSL corporativo
